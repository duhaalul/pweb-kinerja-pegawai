<%- include('../partials/head') %>
<%- include('../partials/navbar') %>
<div class="mb-6 flex items-center justify-between flex-wrap gap-3">
  <div>
    <h2 class="text-2xl font-bold"><%= tugas.title %></h2>
    <p class="text-muted-foreground text-sm">Detail Penugasan</p>
  </div>
  <% if (user.role === 'pimpinan') { %>
  <div class="flex gap-2">
    <a href="/tugas/<%= tugas.id %>/edit" class="inline-flex items-center justify-center rounded-md text-sm font-medium border border-input bg-background hover:bg-accent h-9 px-4 transition-all">Edit</a>
    <% if (tugas.status === 'in_progress') { %>
    <form action="/tugas/<%= tugas.id %>/selesai" method="POST">
      <button type="submit" class="inline-flex items-center justify-center rounded-md text-sm font-medium bg-green-600 text-white hover:bg-green-700 h-9 px-4 transition-all">✅ Tandai Selesai</button>
    </form>
    <% } %>
  </div>
  <% } %>
</div>

<div class="grid md:grid-cols-3 gap-4 mb-6">
  <div data-slot="card" class="rounded-xl border bg-card p-4 shadow-sm">
    <p class="text-xs text-muted-foreground mb-1">Pegawai</p>
    <p class="font-medium"><%= tugas.assigned_to_name || '-' %></p>
  </div>
  <div data-slot="card" class="rounded-xl border bg-card p-4 shadow-sm">
    <p class="text-xs text-muted-foreground mb-1">Status</p>
    <span class="text-sm px-2 py-0.5 rounded-full border <%= tugas.status==='completed' ? 'bg-green-500/10 text-green-700 border-green-500/30' : tugas.status==='in_progress' ? 'bg-blue-500/10 text-blue-700 border-blue-500/30' : 'bg-yellow-500/10 text-yellow-700 border-yellow-500/30' %>">
      <%= tugas.status %>
    </span>
  </div>
  <div data-slot="card" class="rounded-xl border bg-card p-4 shadow-sm">
    <p class="text-xs text-muted-foreground mb-1">Tenggat</p>
    <p class="font-medium"><%= tugas.due_date ? new Date(tugas.due_date).toLocaleDateString('id-ID') : '-' %></p>
  </div>
</div>

<% if (tugas.description) { %>
<div data-slot="card" class="rounded-xl border bg-card p-4 shadow-sm mb-6">
  <p class="text-xs text-muted-foreground mb-2">Deskripsi</p>
  <p class="text-sm"><%= tugas.description %></p>
</div>
<% } %>

<!-- Progress / Kiriman Pegawai -->
<div data-slot="card" class="rounded-xl border bg-card shadow-sm mb-6">
  <div class="p-4 border-b"><h3 class="font-semibold">Kiriman Tugas Pegawai</h3></div>
  <% if (progress.length > 0) { %>
    <% progress.forEach(p => { %>
    <div class="p-4 border-b last:border-0">
      <div class="flex items-start justify-between gap-2">
        <div class="flex-1">
          <p class="text-sm font-medium"><%= p.created_by_name || '-' %> — <%= new Date(p.progress_date).toLocaleDateString('id-ID') %></p>
          <p class="text-sm text-muted-foreground mt-1 whitespace-pre-line"><%= p.description %></p>
          <% if (p.attachment) { %>
          <a href="/uploads/<%= p.attachment %>" target="_blank" class="text-xs text-primary underline mt-1 inline-block">📎 Lihat Lampiran</a>
          <% } %>
        </div>
        <span class="text-xs px-2 py-0.5 rounded-full border <%= p.status==='completed' ? 'bg-green-500/10 text-green-700 border-green-500/30' : 'bg-yellow-500/10 text-yellow-700 border-yellow-500/30' %>">
          <%= p.status %>
        </span>
      </div>
      <% if (user.role === 'pimpinan' && p.status !== 'completed') { %>
      <form action="/tugas/<%= tugas.id %>/revisi" method="POST" class="mt-3 flex gap-2">
        <input type="hidden" name="progress_id" value="<%= p.id %>"/>
        <input type="text" name="catatan" placeholder="Catatan revisi..." required
          class="h-8 flex-1 rounded-md border border-input bg-background px-3 text-sm outline-none focus-visible:border-ring"/>
        <button type="submit" class="inline-flex items-center justify-center rounded-md text-sm font-medium bg-orange-500 text-white hover:bg-orange-600 h-8 px-3 transition-all">
          Kirim Revisi
        </button>
      </form>
      <% } %>
    </div>
    <% }) %>
  <% } else { %>
  <div class="p-6 text-center text-sm text-muted-foreground">Belum ada kiriman tugas dari pegawai.</div>
  <% } %>
</div>

<a href="<%= user.role==='pimpinan' ? '/tugas' : '/tugas/pegawai' %>" class="inline-flex items-center justify-center rounded-md text-sm font-medium border border-input bg-background hover:bg-accent h-9 px-4 transition-all">
  ← Kembali
</a>
<%- include('../partials/footer') %>
