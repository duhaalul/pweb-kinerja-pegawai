<%- include('../partials/head') %>
<%- include('../partials/navbar') %>

<div class="page-header">
  <div class="page-header-text">
    <h2>Tugas Saya</h2>
    <p>Daftar penugasan yang diberikan kepadamu</p>
  </div>
</div>

<form method="GET" class="filter-bar">
  <input type="text" name="search" value="<%= search %>" placeholder="Cari judul..." class="form-input" style="width:220px"/>
  <select name="status" class="form-select" style="width:160px">
    <option value="">Semua Status</option>
    <option value="assigned" <%= statusFilter==='assigned'?'selected':'' %>>Assigned</option>
    <option value="in_progress" <%= statusFilter==='in_progress'?'selected':'' %>>In Progress</option>
    <option value="completed" <%= statusFilter==='completed'?'selected':'' %>>Selesai</option>
  </select>
  <button type="submit" class="btn btn-primary">Filter</button>
  <a href="/tugas/pegawai" class="btn btn-outline">Reset</a>
</form>

<div class="card">
  <div class="item-list">
    <% tugas.forEach(t => { %>
    <div class="item-row">
      <div class="item-info">
        <div class="item-title"><%= t.title %></div>
        <div class="item-meta">Dari: <%= t.assigned_by_name || '—' %> · Tenggat: <%= t.due_date ? new Date(t.due_date).toLocaleDateString('id-ID') : '—' %></div>
      </div>
      <div class="item-actions">
        <span class="badge <%= t.priority==='high'?'badge-danger':t.priority==='medium'?'badge-warning':'badge-success' %>">
          <%= t.priority==='high'?'Tinggi':t.priority==='medium'?'Sedang':'Rendah' %>
        </span>
        <span class="badge <%= t.status==='completed'?'badge-success':t.status==='in_progress'?'badge-accent':'badge-gray' %>">
          <%= t.status==='completed'?'Selesai':t.status==='in_progress'?'Berjalan':'Assigned' %>
        </span>
        <a href="/tugas/<%= t.id %>/detail" class="btn btn-outline btn-xs">Detail</a>
        <% if (t.status !== 'completed') { %>
        <a href="/tugas/<%= t.id %>/submit" class="btn btn-primary btn-xs">Kumpulkan</a>
        <% } %>
      </div>
    </div>
    <% }) %>
    <% if (tugas.length === 0) { %>
    <div class="empty-state"><p>Belum ada tugas yang diberikan kepadamu.</p></div>
    <% } %>
  </div>
</div>

<% if (totalPages > 1) { %>
<div class="pagination">
  <% for(let i=1; i<=totalPages; i++) { %>
  <a href="?page=<%= i %>&search=<%= search %>&status=<%= statusFilter %>" class="page-btn <%= i===currentPage?'active':'' %>"><%= i %></a>
  <% } %>
</div>
<% } %>

<%- include('../partials/footer') %>