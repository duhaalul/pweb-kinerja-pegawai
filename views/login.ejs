<%- include('partials/head') %>
<body>
<div class="login-page">
  <div class="login-wrap">
    <div class="login-form-side">
      <div class="login-brand-mark">K</div>
      <h1>Selamat Datang</h1>
      <p>Masuk ke akun Anda untuk melanjutkan</p>
      <% if (locals.error && error) { %>
      <div class="alert alert-danger"><%= error %></div>
      <% } %>
      <form action="/login" method="POST">
        <div class="form-group">
          <label class="form-label" for="username">Username</label>
          <input type="text" name="username" id="username" class="form-input" placeholder="Masukkan username" required/>
        </div>
        <div class="form-group">
          <label class="form-label">
            Password
            <a href="#" style="float:right;font-weight:400;color:var(--accent);font-size:12px;text-decoration:none">Lupa password?</a>
          </label>
          <input type="password" name="password" class="form-input" placeholder="••••••••" required/>
        </div>
        <button type="submit" class="btn btn-primary" style="width:100%;justify-content:center;padding:10px 14px;font-size:14px;margin-top:4px">
          Masuk
        </button>
      </form>
      <div class="login-footer-text">
        Belum punya akun? <a href="#">Daftar</a><br/>
        Dengan masuk, Anda menyetujui <a href="#">Ketentuan Layanan</a> dan <a href="#">Kebijakan Privasi</a>.
      </div>
    </div>
    <div class="login-visual">
      <div class="login-visual-content">
        <div class="login-visual-eyebrow">Sistem Informasi</div>
        <h2>Sistem Kinerja<br/>Pegawai</h2>
        <p>Kelola penugasan, pantau kinerja, dan catat logbook aktivitas harian pegawai secara terpusat.</p>
        <div class="login-dots">
          <span></span><span></span><span></span>
        </div>
      </div>
    </div>
  </div>
</div>
</body>
</html>